<launch>

  <!-- A simple launch file for the nmea_serial_driver node. -->
  <!-- This launch file configures the NMEA GPS serial driver with customizable parameters -->

  <!-- Serial port configuration -->
  <arg name="port" default="/dev/ttyUSB0" />
  <arg name="baud" default="460800" />
  
  <!-- TF frame ID for published messages -->
  <arg name="frame_id" default="gps" />
  
  <!-- Time reference configuration -->
  <arg name="use_GNSS_time" default="False" />
  <arg name="time_ref_source" default="gps" />
  
  <!-- NMEA sentence type configuration -->
  <arg name="useRMC" default="False" />

  <!-- NMEA Serial Driver Node -->
  <!-- Package name corrected to match package.xml: nema_navsat_driver -->
  <node name="nmea_serial_driver" pkg="nema_navsat_driver" type="nmea_serial_driver" output="screen" respawn="true" respawn_delay="3" required="false">
    <param name="port" value="$(arg port)"/>
    <param name="baud" value="$(arg baud)" />
    <param name="frame_id" value="$(arg frame_id)" />
    <param name="use_GNSS_time" value="$(arg use_GNSS_time)" />
    <param name="time_ref_source" value="$(arg time_ref_source)" />
    <param name="useRMC" value="$(arg useRMC)" />
  </node>

</launch>