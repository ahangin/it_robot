
<launch>
<!-- 纯定位方式，设置参数服务器，后续需要使用 -->
<param name="/pure_localization" type="bool" value = "true"/>
 <!--- Run cloud_deskewed -->
<!-- <include file="$(find cloud_deskewed)/launch/rs_lidar_deskew.launch" /> -->

<!-- 从 YAML 文件加载参数 -->
<rosparam command="load" file="/home/cst/cartographer/carto_ws/src/cartographer_ros/cartographer_ros/params/pose.yaml" />
<param name="pose_yaml_path" value="$(find cartographer_ros)/params/candidate_poses.yaml"/>

<!--  -->

<param name="robot_description" textfile="$(find cartographer_ros)/urdf/car.urdf" />
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" />

    <!-- pbstream的地址与名称 -->
<arg name="load_state_filename" default="$(env HOME)/maps/map.pbstream"/>

<!-- rviz 重定位 -->
  <node name="pose_initializer" pkg="cartographer_ros" type="pose_initializer" output="screen"
        args="
              -configuration_directory $(find cartographer_ros)/configuration_files
              -configuration_basename yahboomcar_2d_localization.lua
              -load_state_filename $(arg load_state_filename)" >
  </node>

  <!-- 使用bag的时间戳 -->
  <param name="/use_sim_time" value="false" />
  
  <!-- 启动cartographer -->
  <node name="cartographer_node" pkg="cartographer_ros"
      type="cartographer_node" args="
          -configuration_directory $(find cartographer_ros)/configuration_files
          -configuration_basename yahboomcar_2d_localization.lua
          -load_state_filename $(arg load_state_filename)"
      output="screen">
    <remap from="points2" to="cloud_deskewed" />
         <!-- <remap from="points2" to="rslidar_points" /> -->
    <remap from="imu" to="/imu/data" />
  </node>

  <!-- 生成ros格式的地图 -->
  <node name="cartographer_occupancy_grid_node" pkg="cartographer_ros"
      type="cartographer_occupancy_grid_node" args="-resolution 0.05" />

  <!-- 启动rviz -->
  <!-- <node name="rviz" pkg="rviz" type="rviz" required="true"
      args="-d $(find cartographer_ros)/configuration_files/demo_2d.rviz" /> -->

  <!-- auto_relocalizer -->
  <!-- <node name="auto_relocalizer" pkg="cartographer_ros" type="auto_relocalizer" output="screen"></node> -->

  <!-- ekf   -->
  <!-- <node pkg="robot_localization" type="ekf_localization_node" name="ekf_se" clear_params="true"> -->
  <!-- <rosparam command="load" file="/home/cst/cartographer/carto_ws/src/cartographer_ros/cartographer_ros/params/ekf_template.yaml" /> -->
    <!--  Placeholder for output topic remapping
    <remap from="odometry/filtered" to=""/>
    <remap from="accel/filtered" to=""/>
    -->
  <!-- </node> -->

  <!-- save_pose -->
  <!-- <node name="pose_recorder" pkg="cartographer_ros" type="pose_recorder" output="screen">
        <param name="update_interval" value="1.0" />
        <param name="output_file" value="/home/cst/cartographer/carto_ws/src/cartographer_ros/cartographer_ros/params/pose.yaml" />
  </node> -->

</launch>